# Ahrefs API key — get from https://ahrefs.com/api
AHREFS_API_KEY=

# Server port
PORT=3000

# API timeout in milliseconds (default: 30 seconds)
TIMEOUT_MS=90000

# SQLite database file path
DB_PATH=./analytics.db

# ── Project configuration ────────────────────────────────────────────────────
# Ahrefs project ID — used by GSC and Rank Tracker widgets
DEFAULT_PROJECT_ID=

# Ahrefs project ID specifically for Web Analytics widgets (falls back to DEFAULT_PROJECT_ID if not set)
DEFAULT_WEB_ANALYTICS_PROJECT_ID=

# Ahrefs Brand Radar report ID — used by all Brand Radar widgets
DEFAULT_REPORT_ID=

# Your domain — used by Site Explorer and to filter competitor tables
DEFAULT_DOMAIN=

# Your brand name — used to filter branded keywords in GSC widgets
DEFAULT_BRAND_NAME=

# Default country for SERP lookups (ISO 2-letter code, e.g. us)
DEFAULT_COUNTRY=us

# Competitor domains to exclude from 3rd-party tables (comma-separated)
DEFAULT_COMPETITORS_DOMAINS=

# Cron schedule for scheduled data refresh (default: 2am daily)
CRON_SCHEDULE=0 2 * * *
